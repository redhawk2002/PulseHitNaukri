# --- Authentication (Cookie-based - Recommended) ---
# Export cookies from your browser using the Cookie-Editor extension while logged into naukri.com
# Paste the exported JSON as a single line value here.
# Refresh these every ~30 days when the session expires.
NAUKRI_COOKIES='[{"name":"...","value":"...","domain":".naukri.com",...}]'

# --- Naukri credentials (kept for reference, no longer used for login) ---
NAUKRI_EMAIL=your_email@example.com
NAUKRI_PASSWORD=your_password

# --- Optional: Configure cron schedule (Defaults to 09:00 and 21:00) ---
# CRON_SCHEDULE="0 9,21 * * *"

# --- Dashboard Auth ---
DASHBOARD_PASSWORD=your_secure_dashboard_password

# --- Playwright browser location (required on Render) ---
PLAYWRIGHT_BROWSERS_PATH=0
